# Keep the Docker build context small & reproducible.
**/node_modules
**/.venv
.venv-twin
.venv-pin
backend/venv
**/__pycache__
**/*.pyc
**/*.db
frontend/dist
landing/.next
.git
.github
backend/smoke_*.py
# Root-level throwaway scripts only — NOT **/_*.py, which would exclude
# app/services/ingestion/_primitives.py from the image (runtime breakage).
backend/_*.py
docs
